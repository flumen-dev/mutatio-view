{
  "name": "@flumen-dev/mutatio-view",
  "version": "0.1.0",
  "type": "module",
  "description": "A Vue 3 diff editor component built on @git-diff-view/core",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flumen-dev/mutatio-view.git"
  },
  "exports": {

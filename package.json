{
  "name": "mutatio-view-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter @flumen-dev/mutatio-view build",
    "dev": "pnpm -r --parallel dev",
    "dev:playground": "pnpm -r --filter @flumen-dev/playground dev",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "typecheck": "pnpm -r typecheck",
    "release": "./scripts/release.sh"
  },
  "devDependencies": {
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.0",
    "vite": "^6.3.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@10.30.3"
}

  },
  "dependencies": {
    "@git-diff-view/core": "^0.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.9.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@10.30.3"
